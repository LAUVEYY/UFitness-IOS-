{
  "expo": {
    "name": "UFitness",
    "slug": "UFitness",
    "scheme": "ufitness",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF3B30"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.student.ufitness",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Allow UFitness to track your route while the app is in use.",
        "NSLocationAlwaysUsageDescription": "Allow UFitness to track your route even when the app is in the background.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.student.ufitness",
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCTwkArNty4hvcgEApPTXey2-Z3fuVp0S0"
        }
      },
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.health.READ_STEPS",
        "android.permission.health.WRITE_EXERCISE",
        "android.permission.health.WRITE_ACTIVE_CALORIES_BURNED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router"
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow Ufitness to track your steps to calculate daily activity."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Ufitness to sync your class schedule from your calendar."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow UFitness to track your walks and runs to compete in leaderboards.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin",
      "expo-font",
      "expo-audio",
      "expo-health-connect",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF3B30",
          "sounds": [
            "./assets/sounds/ping.mp3"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "699cff25-c98b-4f47-a679-a496af95bc6c"
      }
    }
  }
}